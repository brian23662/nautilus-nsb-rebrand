# Google Calendar — used by /api/schedule for the live class schedule.
# Restrict this key to your domain in Google Cloud Console.
GOOGLE_CALENDAR_API_KEY=
GOOGLE_CALENDAR_ID=

# Web3Forms — used by the contact form. Get a key at https://web3forms.com
# Public because Web3Forms keys are domain-scoped and safe to expose.
NEXT_PUBLIC_WEB3FORMS_KEY=

# Anthropic — optional. Used by /api/chat for the chatbot.
# Without this, the bot uses a small rules-based fallback.
ANTHROPIC_API_KEY=
